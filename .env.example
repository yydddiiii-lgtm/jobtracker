# Railway 会自动提供 DATABASE_URL 环境变量
# 你只需要设置 JWT_SECRET

# JWT 密钥（至少32字符）
# 生成命令：openssl rand -base64 32 或 node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters!!

# JWT 令牌过期时间
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 服务器端口（Railway 会自动设置）
PORT=4000

# 环境
NODE_ENV=production

# Redis（可选）
# REDIS_URL=redis://localhost:6379